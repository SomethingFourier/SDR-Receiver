	(text "3.3V_A Regulator"
		(exclude_from_sim no)
		(at 218.186 89.916 0)
		(effects
			(font
				(size 1.524 1.524)
				(thickness 0.508)
				(bold yes)
			)
		)
		(uuid "50117701-5903-43b8-a9c8-a49d08a3b765")
	)
	(text "By connecting the ADJ pin to V- (gnd) with this jumper,\nthe POE module will output 5.65V rather than 5V,\nallowing us to use a low-noise LDO to get as clean \nof a 5V rail as possible."
		(exclude_from_sim no)
		(at 102.87 79.248 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "92cc3148-75b1-4b25-b60d-ac170c82c096")
	)
	(text "The ST pins here can be used to determine which power source\nis active. We could hook them up to GPIO pins if we wanted to."
		(exclude_from_sim no)
		(at 205.486 125.476 0)
		(effects
			(font
				(size 0.762 0.762)
				(thickness 0.0953)
			)
		)
		(uuid "a88fe33d-1190-490f-92d1-8ae8204449b1")
	)
	(text "+2.4V Regulator"
		(exclude_from_sim no)
		(at 168.656 27.432 0)
		(effects
