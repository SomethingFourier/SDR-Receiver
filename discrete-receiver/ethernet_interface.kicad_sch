				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
		)
		(uuid "5f5275ab-1322-41e3-96a3-8ddb045ff533")
	)
	(text "We should consider doing something with this shield connection."
		(exclude_from_sim no)
		(at 87.63 192.786 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "90894b01-c6c6-4a52-a6fd-5ccd2aea5093")
	)
	(text "By connecting the ADJ pin to V- (gnd) with this jumper,\nthe POE module will output 5.65V rather than 5V,\nallowing us to use a low-noise LDO to get as clean \nof a 5V rail as possible."
		(exclude_from_sim no)
		(at 133.35 32.258 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "de0a09e1-1cd0-42f6-9c81-8cef50b86596")
	)
