	(text "These LEDs are wired such that nINTSEL is pulled low.\nThis causes the LAN8720a to drive the LEDs active high.\nWe've also ensured that REGOFF is set to zero such that\nthe internal 1.2V regulator is enabled."
		(exclude_from_sim no)
		(at 87.884 186.69 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "36748199-1a87-4d88-bc54-df5b1aa6cfd0")
	)
	(text "Ethernet Transmission Module "
		(exclude_from_sim no)
		(at 207.264 189.992 0)
		(effects
			(font
				(size 1.778 1.778)
				(thickness 0.3556)
				(bold yes)
				(italic yes)
			)
		)
		(uuid "37d2246d-7654-41e7-929a-bde8ac055b86")
	)
	(text "This is the ideal for how the receiver will communicate with the computer \nbecause we want to be able to send all 96 kHz of bandwidth from the ADC \nto the computer, something the built-in USB on the PR2350 is incapable of."
		(exclude_from_sim no)
		(at 177.8 170.434 0)
		(effects
			(font
				(size 1.27 1.27)
				(thickness 0.254)
				(bold yes)
			)
			(justify left)
		)
		(uuid "55127803-8e37-4e20-a9f1-3fca970d0f2f")
	)
	(text "We should consider doing something with this shield connection."
		(exclude_from_sim no)
		(at 87.63 192.786 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "90894b01-c6c6-4a52-a6fd-5ccd2aea5093")
	)
